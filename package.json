    "framer-motion": "^12.23.22",
    "nodemailer": "^7.0.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.16",
